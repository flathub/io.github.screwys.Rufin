{
  "app-id": "io.github.screwys.Rufin",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "command": "rufin",
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_NET_OFFLINE": "true"
    }
  },
  "finish-args": [
    "--share=ipc",
    "--share=network",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--socket=pulseaudio",
    "--device=dri",
    "--filesystem=xdg-music:ro",
    "--filesystem=xdg-run/app/com.discordapp.Discord:create"
  ],
  "modules": [
    {
      "name": "rufin",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm644 cargo/config .cargo/config.toml",
        "cargo fetch --locked --offline --manifest-path Cargo.toml --verbose",
        "cargo build --release --locked --offline -p rufin-app",
        "install -Dm755 target/release/rufin /app/bin/rufin.bin",
        "install -Dm755 packaging/flatpak/rufin-flatpak /app/bin/rufin",
        "install -Dm644 data/io.github.screwys.Rufin.desktop /app/share/applications/io.github.screwys.Rufin.desktop",
        "install -Dm644 data/io.github.screwys.Rufin.metainfo.xml /app/share/metainfo/io.github.screwys.Rufin.metainfo.xml",
        "install -Dm644 data/icons/hicolor/scalable/apps/io.github.screwys.Rufin.svg /app/share/icons/hicolor/scalable/apps/io.github.screwys.Rufin.svg",
        "install -Dm644 -t /app/share/icons/hicolor/scalable/status data/icons/hicolor/scalable/status/*.svg",
        "install -Dm644 -t /app/share/icons/hicolor/512x512/apps data/icons/hicolor/512x512/apps/*.png",
        "install -Dm644 -t /app/share/icons/hicolor/64x64/apps data/icons/hicolor/64x64/apps/*.png"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/screwys/Rufin.git",
          "tag": "v0.3.14",
          "commit": "1db1e1c750c2918eabb2666616a2638ba45019a5",
          "x-checker-data": {
            "type": "json",
            "url": "https://api.github.com/repos/screwys/Rufin/releases/latest",
            "tag-query": ".tag_name",
            "version-query": "$tag | sub(\"^v\"; \"\")",
            "timestamp-query": ".published_at",
            "is-main-source": true,
            "release-url-template": "https://github.com/screwys/Rufin/releases/tag/v$version"
          }
        },
        "cargo-sources.json"
      ]
    }
  ]
}
